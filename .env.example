# Application Settings
APP_NAME="Muxarr"
APP_VERSION="0.1.0"
ENVIRONMENT=development
DEBUG=true
PRODUCTION=false

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Database Configuration
# Options: sqlite or postgresql
DATABASE_TYPE=sqlite

# PostgreSQL settings (if DATABASE_TYPE=postgresql)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=webapp_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=webapp_db

# SQLite settings (if DATABASE_TYPE=sqlite)
SQLITE_DATABASE_PATH=./muxarr.db

# Security
# Generate a secure key for production: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_MIN_LENGTH=8

# Logging
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Radarr Configuration
RADARR_URL=http://localhost:7878
RADARR_API_KEY=

# Sonarr Configuration
SONARR_URL=http://localhost:8989
SONARR_API_KEY=

# External Tools
# Paths to required binaries (defaults work if they're in PATH)
FFPROBE_PATH=ffprobe
MKVPROPEDIT_PATH=mkvpropedit
MKVMERGE_PATH=mkvmerge
